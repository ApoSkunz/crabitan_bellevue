{
    "name": "crabitan/bellevue",
    "description": "Crabitan Bellevue - Site e-commerce vente de vins v3",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "firebase/php-jwt": "^6.10",
        "phpmailer/phpmailer": "^6.9",
        "tecnickcom/tcpdf": "^6.7",
        "league/iso3166": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Core\\":       "src/Core/",
            "Controller\\": "src/Controller/",
            "Model\\":      "src/Model/",
            "Middleware\\": "src/Middleware/",
            "Service\\":    "src/Service/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
