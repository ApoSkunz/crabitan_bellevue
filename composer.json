{
    "name": "crabitan/bellevue",
    "description": "Crabitan Bellevue - Site e-commerce vente de vins v3",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "phpmailer/phpmailer": "^6.9",
        "tecnickcom/tcpdf": "^6.7"
    },
    "autoload": {
        "psr-4": {
            "Core\\":       "src/Core/",
            "Controller\\": "src/Controller/",
            "Model\\":      "src/Model/",
            "Middleware\\": "src/Middleware/",
            "Service\\":    "src/Service/",
            "Exception\\": "src/Exception/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    }
}
